# OpenAI API key (used for GPT-4o, embeddings, TTS, Whisper)
OPENAI_API_KEY=sk-proj-...

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Cache / Broker
REDIS_URL=redis://localhost:6379/0

# Message Queue
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_ARTICLES=raw-articles
KAFKA_TOPIC_PROCESSED_ARTICLES=processed-articles
KAFKA_TOPIC_VIDEO_JOBS=video-jobs
KAFKA_TOPIC_TRANSLATION_JOBS=translation-jobs

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/etnews

# Service Ports
API_SERVER_PORT=8000
FEATURE_FEED_PORT=8001
FEATURE_BRIEFING_PORT=8002
FEATURE_VIDEO_PORT=8003
FEATURE_ARC_PORT=8004
FEATURE_VERNACULAR_PORT=8005

# App Config
LOG_LEVEL=INFO
ENVIRONMENT=development
